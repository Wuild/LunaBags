<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <Button name="LunaBagsItemButtonTemplate" virtual="true" inherits="ContainerFrameItemButtonTemplate">
        <Size x="36" y="36"/>
    </Button>

    <Frame name="LunaBagsOneBagFrame" parent="UIParent" hidden="true" movable="true" enableMouse="true" clampedToScreen="true" frameStrata="DIALOG">
        <Size x="520" y="500"/>
        <Anchors>
            <Anchor point="BOTTOMRIGHT" x="-34" y="126"/>
        </Anchors>
        <Frames>
            <Frame parentKey="Header">
                <Anchors>
                    <Anchor point="TOPLEFT" x="12" y="-28"/>
                    <Anchor point="TOPRIGHT" x="-32" y="-28"/>
                </Anchors>
                <Size y="34"/>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Title" inherits="GameFontNormal">
                            <Anchors><Anchor point="LEFT" x="8" y="0"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
                <Frames>
                    <EditBox name="LunaBagsSearchBox" parentKey="SearchBox" inherits="InputBoxTemplate" autoFocus="false">
                        <Size x="150" y="20"/>
                        <Anchors><Anchor point="RIGHT" x="-72" y="0"/></Anchors>
                        <Scripts>
                            <OnTextChanged>LunaBagsOneBag_SearchChanged(self)</OnTextChanged>
                            <OnEscapePressed>self:ClearFocus()</OnEscapePressed>
                        </Scripts>
                    </EditBox>
                    <Button parentKey="SearchToggle" inherits="UIPanelButtonTemplate">
                        <Size x="20" y="20"/>
                        <Anchors><Anchor point="RIGHT" x="-48" y="0"/></Anchors>
                    </Button>
                    <Button parentKey="SortButton" inherits="UIPanelButtonTemplate">
                        <Size x="20" y="20"/>
                        <Anchors><Anchor point="RIGHT" x="-24" y="0"/></Anchors>
                        <Scripts>
                            <OnClick>LunaBagsOneBag_SortClicked()</OnClick>
                        </Scripts>
                    </Button>
                </Frames>
            </Frame>

            <Frame parentKey="Content">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Header" relativePoint="BOTTOMLEFT" x="0" y="-6"/>
                    <Anchor point="BOTTOMRIGHT" x="-8" y="34"/>
                </Anchors>
            </Frame>

            <StatusBar parentKey="MoneyBar">
                <Anchors>
                    <Anchor point="BOTTOMLEFT" x="12" y="12"/>
                    <Anchor point="BOTTOMRIGHT" x="-12" y="12"/>
                </Anchors>
                <Size y="20"/>
                <BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Label" inherits="GameFontNormalSmall">
                            <Anchors><Anchor point="LEFT" x="8" y="0"/></Anchors>
                        </FontString>
                        <FontString parentKey="Text" inherits="GameFontHighlightSmall">
                            <Anchors><Anchor point="RIGHT" x="-8" y="0"/></Anchors>
                        </FontString>
                    </Layer>
                </Layers>
            </StatusBar>
        </Frames>
    </Frame>
</Ui>
